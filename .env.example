# ========================================
# AI Panelist System - Environment Configuration
# ========================================
# Copy this file to .env and configure your settings
# cp .env.example .env

# ========================================
# NVIDIA API Configuration (REQUIRED)
# ========================================
# Get your free API key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_ENDPOINT=https://integrate.api.nvidia.com/v1

# ========================================
# Database Configuration
# ========================================
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ========================================
# Server Configuration
# ========================================
SERVER_PORT=8080

# ========================================
# Logging Configuration
# ========================================
# Options: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# ========================================
# JVM Configuration
# ========================================
# Adjust based on your system resources
JAVA_OPTS=-Xms512m -Xmx2048m -XX:+UseG1GC

# ========================================
# PgAdmin Configuration (Development Only)
# ========================================
PGADMIN_EMAIL=admin@aipanelist.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ========================================
# Advanced Configuration (Optional)
# ========================================
# Uncomment and modify as needed

# NVIDIA API Settings
# NVIDIA_API_RATE_LIMIT=60
# NVIDIA_API_MAX_CONNECTIONS=10
# NVIDIA_API_TIMEOUT_MS=30000

# File Upload Settings
# STORAGE_UPLOAD_DIR=/app/data/uploads
# STORAGE_MAX_FILE_SIZE=52428800

# Processing Settings
# PROCESSING_CHUNK_SIZE=100000
# PROCESSING_MAX_RETRIES=3
# PROCESSING_RETRY_DELAY_MS=1000

# Async Thread Pool Settings
# ASYNC_CORE_POOL_SIZE=10
# ASYNC_MAX_POOL_SIZE=20
# ASYNC_QUEUE_CAPACITY=100

# Database Connection Pool
# SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
# SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
# SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000

# Show SQL queries (useful for debugging)
# SHOW_SQL=true
